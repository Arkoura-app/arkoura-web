# API base URL consumed by the frontend
NEXT_PUBLIC_API_URL=https://api.example.com

# Cloudflare Web Analytics beacon token
NEXT_PUBLIC_CF_ANALYTICS=

# Firebase project config (JSON-encoded)
NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"","authDomain":"","projectId":"","storageBucket":"","messagingSenderId":"","appId":""}

# Resend API key (for transactional email)
RESEND_API_KEY=

# Firebase Admin SDK (server-side — waitlist API route)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
